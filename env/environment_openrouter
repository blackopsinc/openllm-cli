# OpenRouter provider configuration
# Usage: source env/environment_openrouter
# Browse models: https://openrouter.ai/models

# ── Provider ────────────────────────────────────────────────
export LLM_PROVIDER=openrouter
export LLM_MODEL=openrouter/auto
# Other OpenRouter models (free tier):
#   openrouter/auto                    (auto-select best available)
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-7b-instruct:free
#   google/gemma-3-27b-it:free

# ── API key ─────────────────────────────────────────────────
export OPENROUTER_API_KEY=""

# ── Request settings ────────────────────────────────────────
export LLM_MAX_TOKENS=8096       # max tokens to generate
export LLM_TIMEOUT=600           # LLM request timeout in seconds
export LLM_SHELL_TIMEOUT=60      # shell command timeout in seconds (auto mode)
export LLM_STREAM=1              # 1=streaming tokens, 0=wait for full response

# ── Behaviour ───────────────────────────────────────────────
export LLM_SYSTEM_PROMPT=""      # custom system prompt (optional)
export LLM_AUTO_APPROVE=0        # 1=skip tool-use confirmations (non-auto mode)
export LLM_SKILLS_MODE=0         # 1=enable skills mode (reads SKILL.md)
export LLM_INTERACTIVE=0         # 1=force interactive REPL even when piped

# ── Debug ───────────────────────────────────────────────────
export LLM_VERBOSE=false         # true=debug logging
